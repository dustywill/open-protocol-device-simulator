# Auto detect text files and perform LF normalization
* text=auto

# Rust sources
*.rs text eol=lf
*.toml text eol=lf
*.lock text eol=lf

# Frontend sources
*.js text eol=lf
*.ts text eol=lf
*.svelte text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.db binary
